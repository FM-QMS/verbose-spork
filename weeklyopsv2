// ── DELTA ───────────────────────────────────────────────────────
function calcDelta(currId,prevId,deltaId,dir) {
  const curr=parseFloat(document.getElementById(currId).value);
  const prev=parseFloat(document.getElementById(prevId).value);
  const el=document.getElementById(deltaId);
  if(isNaN(curr)||isNaN(prev)||prev===0){el.textContent='—';el.className='delta delta-flat';return;}
  const diff=curr-prev,pct=Math.round((diff/prev)*100),sign=diff>0?'+':'';
  el.textContent=`${sign}${diff} (${sign}${pct}%)`;
  const d2=dir||'down';
  if(diff===0) el.className='delta delta-flat';
  else if((d2==='down'&&diff<0)||(d2==='up'&&diff>0)) el.className='delta delta-down';
  else el.className='delta delta-up';
}

// ── BUILD METRIC TABLE ──────────────────────────────────────────
function buildMetricTable(containerId, metrics) {
  const el=document.getElementById(containerId);
  let html=`<table class="metric-table">
    <thead><tr>
      <th class="th left" style="width:42%;">Metric</th>
      <th class="th" style="width:20%;">This week</th>
      <th class="th" style="width:20%;">Last week</th>
      <th class="th" style="width:18%;">vs. last week</th>
    </tr></thead><tbody>`;
  metrics.forEach(m=>{
    const dir=m.dir||'down';
    html+=`<tr class="metric-row">
      <td><span class="metric-name">${m.label}</span></td>
      <td><input type="number" id="f-${m.id}" placeholder="0" min="0" oninput="calcDelta('f-${m.id}','p-${m.id}','d-${m.id}','${dir}')" /></td>
      <td><input type="number" id="p-${m.id}" placeholder="prev." min="0" oninput="calcDelta('f-${m.id}','p-${m.id}','d-${m.id}','${dir}')" /></td>
      <td style="text-align:center;"><span class="delta delta-flat" id="d-${m.id}">—</span></td>
    </tr>`;
  });
  html+='</tbody></table>';
  el.innerHTML=html;
}

