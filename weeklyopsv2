// ── STORAGE ─────────────────────────────────────────────────────
async function loadAdv() { 
  const data = localStorage.getItem(STORAGE_ADV);
  advEntries = data ? JSON.parse(data) : []; 
}
async function loadFitter() { 
  const data = localStorage.getItem(STORAGE_FITTER);
  fitterEntries = data ? JSON.parse(data) : []; 
}
async function saveAdv() { 
  localStorage.setItem(STORAGE_ADV, JSON.stringify(advEntries)); 
}
async function saveFitter() { 
  localStorage.setItem(STORAGE_FITTER, JSON.stringify(fitterEntries)); 
}
// ── SUBMIT ──────────────────────────────────────────────────────
async function submitForm(type) {
  if(type==='adv') {
    const date=document.getElementById('week-date').value;
    const entry={date,weekLabel:getWeekLabel(date),
      submitter:document.getElementById('submitter').value,
      notesMeta:document.getElementById('notes-meta').value,
      metrics:{},advocates:{},
      wins:document.getElementById('wins').value,
      blockers:document.getElementById('blockers').value,
      focus:document.getElementById('focus').value,
    };
    advDeptKeys.forEach(d=>{
      entry.metrics[d]={};
      advDepts[d].metrics.forEach(m=>{const v=document.getElementById('f-'+m.id).value;if(v!=='')entry.metrics[d][m.id]=parseInt(v);});
      entry.advocates[d]=advDepts[d].advocates.map((a,i)=>({name:a.name,out:document.getElementById(d+'-out-'+i).value,in:document.getElementById(d+'-in-'+i).value,talk:document.getElementById(d+'-talk-'+i).value,tasks:document.getElementById(d+'-tasks-'+i).value}));
    });
    await loadAdv();
    const idx=advEntries.findIndex(e=>e.date===date);
    if(idx>=0)advEntries[idx]=entry;else advEntries.push(entry);
    advEntries.sort((a,b)=>a.date.localeCompare(b.date));
    await saveAdv();
    document.getElementById('success-msg-adv').style.display='block';
    setTimeout(()=>document.getElementById('success-msg-adv').style.display='none',4000);
  } else {
    const date=document.getElementById('fitter-week-date').value;
    const entry={date,weekLabel:getWeekLabel(date),
      submitter:document.getElementById('fitter-submitter').value,
      notesMeta:document.getElementById('fitter-notes-meta').value,
      metrics:{},
      wins:document.getElementById('fitter-wins').value,
      blockers:document.getElementById('fitter-blockers').value,
      focus:document.getElementById('fitter-focus').value,
    };
    fitterDeptKeys.forEach(d=>{
      entry.metrics[d]={};
      fitterDepts[d].metrics.forEach(m=>{const v=document.getElementById('f-'+m.id).value;if(v!=='')entry.metrics[d][m.id]=parseInt(v);});
    });
    await loadFitter();
    const idx=fitterEntries.findIndex(e=>e.date===date);
    if(idx>=0)fitterEntries[idx]=entry;else fitterEntries.push(entry);
    fitterEntries.sort((a,b)=>a.date.localeCompare(b.date));
    await saveFitter();
    document.getElementById('success-msg-fitter').style.display='block';
    setTimeout(()=>document.getElementById('success-msg-fitter').style.display='none',4000);
  }
}

function clearForm(type) {
  const prefix = type==='fitter' ? ['fitter-submitter','fitter-notes-meta','fitter-wins','fitter-blockers','fitter-focus'] : ['submitter','notes-meta','wins','blockers','focus'];
  prefix.forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; });
  document.querySelectorAll('input[type="number"],input[type="text"]').forEach(el=>{
    if(type==='fitter'&&(el.id.startsWith('f-pfp')||el.id.startsWith('f-fit')||el.id.startsWith('p-pfp')||el.id.startsWith('p-fit')||el.id.startsWith('fitter-'))) el.value='';
    if(type==='adv'&&!el.id.startsWith('f-pfp')&&!el.id.startsWith('f-fit')&&!el.id.startsWith('p-pfp')&&!el.id.startsWith('p-fit')&&!el.id.startsWith('fitter-')) el.value='';
  });
  document.querySelectorAll('.delta').forEach(el=>{el.textContent='—';el.className='delta delta-flat';});
  document.getElementById('success-msg-'+(type==='fitter'?'fitter':'adv')).style.display='none';
}

// ── CHART RENDER ────────────────────────────────────────────────
function renderDeptChart(deptKey) {
  const dept   = advDepts[deptKey]||fitterDepts[deptKey];
  const entries= advDeptKeys.includes(deptKey)?advEntries:fitterEntries;
  const colors = deptColors[deptKey];
  const labels = entries.map(e=>getShortLabel(e.date));
  const datasets= dept.metrics
    .filter(m=>activeMetrics[deptKey].has(m.id))
    .map(m=>{
      const ci=dept.metrics.indexOf(m);
      return {label:m.label,data:entries.map(e=>e.metrics[deptKey]?.[m.id]??null),
        borderColor:colors[ci%colors.length],backgroundColor:colors[ci%colors.length]+'22',
        tension:0.35,pointRadius:4,pointHoverRadius:6,borderWidth:2,spanGaps:true};
    });
  const ctx=document.getElementById(deptKey+'-chart').getContext('2d');
  if(charts[deptKey])charts[deptKey].destroy();
  charts[deptKey]=new Chart(ctx,{type:'line',data:{labels,datasets},options:{
    responsive:true,maintainAspectRatio:false,
    interaction:{mode:'index',intersect:false},
    plugins:{legend:{position:'bottom',labels:{font:{size:11},boxWidth:10,padding:12}},tooltip:{bodyFont:{size:11},titleFont:{size:11}}},
    scales:{x:{grid:{color:'rgba(128,128,128,0.1)'},ticks:{font:{size:10}}},y:{grid:{color:'rgba(128,128,128,0.1)'},ticks:{font:{size:10}},beginAtZero:true}},
  }});

  const snap=document.getElementById(deptKey+'-snap');
  if(!entries.length){snap.innerHTML='';return;}
  const latest=entries[entries.length-1];
  const prev  =entries.length>1?entries[entries.length-2]:null;
  snap.innerHTML=dept.metrics.map(m=>{
    const val=latest.metrics[deptKey]?.[m.id];
    if(val===undefined)return '';
    const prevVal=prev?.metrics[deptKey]?.[m.id];
    let chg='',chgColor='var(--color-text-secondary)';
    if(prevVal!==undefined&&prevVal!==0){
      const diff=val-prevVal,pct=Math.round((diff/prevVal)*100),sign=diff>0?'+':'';
      chg=`${sign}${diff} (${sign}${pct}%)`;
      const dir=m.dir||'down';
      chgColor=diff===0?'var(--color-text-secondary)':((dir==='down'&&diff<0)||(dir==='up'&&diff>0))?'#3B6D11':'#A32D2D';
    }
    return `<div class="snap-card"><div class="snap-lbl">${m.label}</div><div class="snap-val">${val.toLocaleString()}</div>${chg?`<div class="snap-chg" style="color:${chgColor};">${chg}</div>`:''}</div>`;
  }).join('');
}

async function renderAdvTrends() {
  await loadAdv();
  const noData=document.getElementById('adv-no-data');
  if(!advEntries.length){noData.style.display='block';advDeptKeys.forEach(d=>{if(charts[d]){charts[d].destroy();charts[d]=null;}document.getElementById(d+'-snap').innerHTML='';});return;}
  noData.style.display='none';
  advDeptKeys.forEach(d=>renderDeptChart(d));
}

async function renderFitterTrends() {
  await loadFitter();
  const noData=document.getElementById('fitter-no-data');
  if(!fitterEntries.length){noData.style.display='block';fitterDeptKeys.forEach(d=>{if(charts[d]){charts[d].destroy();charts[d]=null;}document.getElementById(d+'-snap').innerHTML='';});return;}
  noData.style.display='none';
  fitterDeptKeys.forEach(d=>renderDeptChart(d));
}

// ── HISTORY ─────────────────────────────────────────────────────
function buildHistoryHTML(entries, deptKeys, deptsObj, chipClass) {
  if(!entries.length) return '<div class="no-data">No check-ins saved yet.</div>';
  return [...entries].reverse().map(e=>{
    const deptChips=deptKeys.map(d=>{
      const metrics=e.metrics[d]||{};
      const ents=Object.entries(metrics);
      if(!ents.length)return '';
      const chips=ents.slice(0,4).map(([k,v])=>{const m=deptsObj[d].metrics.find(x=>x.id===k);return `<span class="chip chip-${d}">${m?m.label:k}: <strong>${v.toLocaleString()}</strong></span>`;}).join('');
      const more=ents.length>4?`<span class="chip">+${ents.length-4} more</span>`:'';
      return `<div style="margin-top:6px;"><span style="font-size:10px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.05em;">${deptsObj[d].label}</span><div class="history-chips">${chips}${more}</div></div>`;
    }).join('');
    return `<div class="history-entry">
      <div><div class="history-date">${e.weekLabel}</div>${e.submitter?`<div style="font-size:12px;color:var(--color-text-secondary);margin-top:1px;">${e.submitter}${e.notesMeta?' · '+e.notesMeta:''}</div>`:''}</div>
      ${deptChips}
      ${e.wins?`<div style="font-size:12px;color:var(--color-text-secondary);margin-top:8px;"><strong style="color:var(--color-text-primary);">Wins:</strong> ${e.wins}</div>`:''}
      ${e.blockers?`<div style="font-size:12px;color:var(--color-text-secondary);margin-top:3px;"><strong style="color:var(--color-text-primary);">Blockers:</strong> ${e.blockers}</div>`:''}
    </div>`;
  }).join('');
}

async function renderAdvHistory() {
  await loadAdv();
  document.getElementById('adv-history-list').innerHTML=buildHistoryHTML(advEntries,advDeptKeys,advDepts,'adv');
}
async function renderFitterHistory() {
  await loadFitter();
  document.getElementById('fitter-history-list').innerHTML=buildHistoryHTML(fitterEntries,fitterDeptKeys,fitterDepts,'fitter');
}

async function clearHistory(type) {
  if(!confirm('Clear all saved check-ins? This cannot be undone.'))return;
  if(type==='adv'){advEntries=[];await saveAdv();renderAdvHistory();advDeptKeys.forEach(d=>{if(charts[d]){charts[d].destroy();charts[d]=null;}});}
  else{fitterEntries=[];await saveFitter();renderFitterHistory();fitterDeptKeys.forEach(d=>{if(charts[d]){charts[d].destroy();charts[d]=null;}});}
}

loadAdv();loadFitter();
</script>
