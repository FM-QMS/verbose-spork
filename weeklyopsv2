
<style>
  *{box-sizing:border-box;}
  .wrap{padding:1rem 0;max-width:780px;}
  .tabs{display:flex;gap:0;margin-bottom:1.25rem;border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);overflow:hidden;width:fit-content;flex-wrap:wrap;}
  .tab{padding:8px 18px;font-size:13px;font-weight:500;cursor:pointer;background:transparent;border:none;color:var(--color-text-secondary);transition:all 0.15s;white-space:nowrap;}
  .tab.active{background:var(--color-text-primary);color:var(--color-background-primary);}
  .page{display:none;}.page.active{display:block;}
  .section{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.25rem 1.5rem;margin-bottom:1rem;}
  .section-title{font-size:11px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.07em;margin:0 0 1rem;}
  .field{margin-bottom:0;}
  label{display:block;font-size:13px;font-weight:500;color:var(--color-text-primary);margin-bottom:5px;}
  label .hint{font-weight:400;color:var(--color-text-tertiary);margin-left:5px;font-size:12px;}
  input[type="text"],input[type="date"],input[type="number"],textarea,select{width:100%;box-sizing:border-box;font-size:14px;}
  textarea{resize:vertical;min-height:60px;}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .sep{border:none;border-top:0.5px solid var(--color-border-tertiary);margin:1rem 0;}
  .dept-pill{font-size:11px;font-weight:500;padding:3px 10px;border-radius:10px;}
  .pill-cgm{background:#E6F1FB;color:#185FA5;}
  .pill-shoe{background:#E1F5EE;color:#0F6E56;}
  .pill-chase{background:#FAEEDA;color:#854F0B;}
  .pill-pfp{background:#EEEDFE;color:#534AB7;}
  .pill-fitter{background:#FAECE7;color:#993C1D;}
  .metric-table{width:100%;border-collapse:collapse;}
  .metric-table .th{font-size:11px;font-weight:500;color:var(--color-text-secondary);padding:0 6px 6px;text-align:center;}
  .metric-table .th.left{text-align:left;padding-left:0;}
  .metric-table tr.metric-row td{padding:4px 6px 4px 0;vertical-align:middle;}
  .metric-table tr.metric-row td:first-child{padding-left:0;}
  .metric-name{font-size:13px;font-weight:500;color:var(--color-text-primary);padding-right:8px;}
  .metric-table input[type="number"]{font-size:13px;padding:5px 8px;min-width:0;}
  .delta{font-size:11px;font-weight:500;padding:3px 7px;border-radius:var(--border-radius-md);text-align:center;white-space:nowrap;min-width:80px;display:inline-block;}
  .delta-up{background:#FCEBEB;color:#A32D2D;}
  .delta-down{background:#EAF3DE;color:#3B6D11;}
  .delta-flat{background:var(--color-background-secondary);color:var(--color-text-secondary);}
  .advocate-block{border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);padding:0.9rem 1rem;margin-bottom:0.75rem;background:var(--color-background-secondary);}
  .advocate-block:last-child{margin-bottom:0;}
  .advocate-name{font-size:13px;font-weight:500;color:var(--color-text-primary);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
  .avatar{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0;}
  .av-cgm{background:#E6F1FB;color:#185FA5;}
  .av-shoe{background:#E1F5EE;color:#0F6E56;}
  .av-chase{background:#FAEEDA;color:#854F0B;}
  .av-pfp{background:#EEEDFE;color:#534AB7;}
  .av-fitter{background:#FAECE7;color:#993C1D;}
  .row4{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
  .submit-row{display:flex;justify-content:flex-end;gap:10px;margin-top:1.25rem;}
  .btn-primary{padding:9px 22px;font-size:14px;font-weight:500;border-radius:var(--border-radius-md);cursor:pointer;border:0.5px solid var(--color-border-secondary);background:var(--color-text-primary);color:var(--color-background-primary);}
  .btn-secondary{padding:9px 16px;font-size:14px;font-weight:500;border-radius:var(--border-radius-md);cursor:pointer;border:0.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-secondary);}
  .success-msg{display:none;background:#E1F5EE;color:#0F6E56;border:0.5px solid #5DCAA5;border-radius:var(--border-radius-md);padding:12px 16px;font-size:14px;font-weight:500;margin-top:1rem;}
  .form-title{font-size:22px;font-weight:500;color:var(--color-text-primary);margin:0 0 4px;}
  .form-meta{display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-top:10px;}
  .week-badge{font-size:13px;color:var(--color-text-secondary);}
  .chart-wrap{position:relative;height:280px;margin:1rem 0;}
  .dept-toggle-group{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:0.75rem;}
  .metric-toggle{padding:4px 10px;font-size:11px;font-weight:500;border-radius:20px;cursor:pointer;border:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);color:var(--color-text-secondary);}
  .metric-toggle.on{border-color:currentColor;}
  .tog-cgm.on{background:#E6F1FB;color:#185FA5;}
  .tog-shoe.on{background:#E1F5EE;color:#0F6E56;}
  .tog-chase.on{background:#FAEEDA;color:#854F0B;}
  .tog-pfp.on{background:#EEEDFE;color:#534AB7;}
  .tog-fitter.on{background:#FAECE7;color:#993C1D;}
  .no-data{text-align:center;padding:3rem 1rem;color:var(--color-text-secondary);font-size:14px;}
  .history-entry{border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-md);padding:0.9rem 1rem;margin-bottom:8px;background:var(--color-background-primary);}
  .history-date{font-size:13px;font-weight:500;color:var(--color-text-primary);}
  .history-chips{display:flex;gap:5px;flex-wrap:wrap;margin-top:6px;}
  .chip{font-size:11px;padding:2px 8px;border-radius:10px;background:var(--color-background-secondary);color:var(--color-text-secondary);}
  .chip-cgm{background:#E6F1FB;color:#185FA5;}
  .chip-shoe{background:#E1F5EE;color:#0F6E56;}
  .chip-chase{background:#FAEEDA;color:#854F0B;}
  .chip-pfp{background:#EEEDFE;color:#534AB7;}
  .chip-fitter{background:#FAECE7;color:#993C1D;}
  .snap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:0.75rem;}
  .snap-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:0.65rem 0.75rem;text-align:center;}
  .snap-val{font-size:18px;font-weight:500;color:var(--color-text-primary);}
  .snap-lbl{font-size:10px;color:var(--color-text-secondary);margin-top:2px;line-height:1.3;}
  .snap-chg{font-size:11px;font-weight:500;margin-top:2px;}
  .dept-snap-title{font-size:11px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.06em;margin:1rem 0 0.5rem;}
  .subsection-label{font-size:12px;font-weight:500;color:var(--color-text-secondary);margin:1rem 0 0.5rem;padding:4px 0;border-bottom:0.5px solid var(--color-border-tertiary);}
</style>

