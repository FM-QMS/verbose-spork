  const dept=advDepts[deptKey]||fitterDepts[deptKey];
  document.getElementById(deptKey+'-toggles').innerHTML=dept.metrics.map(m=>{
    const on=activeMetrics[deptKey].has(m.id)?'on':'';
    return `<button class="metric-toggle ${dept.togCls} ${on}" onclick="toggleMetric('${deptKey}','${m.id}',this)">${m.label}</button>`;
  }).join('');
}

function toggleMetric(deptKey,id,btn) {
  if(activeMetrics[deptKey].has(id)){activeMetrics[deptKey].delete(id);btn.classList.remove('on');}
  else{activeMetrics[deptKey].add(id);btn.classList.add('on');}
  renderDeptChart(deptKey);
}

// ── DATE HELPERS ────────────────────────────────────────────────
function getWeekLabel(dateStr) {
  const d=new Date(dateStr+'T12:00:00'),day=d.getDay(),diff=d.getDate()-day+(day===0?-6:1);
  const mon=new Date(d);mon.setDate(diff);
  const fri=new Date(mon);fri.setDate(mon.getDate()+4);
  const fmt=dt=>dt.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  return `Week of ${fmt(mon)} – ${fmt(fri)}, ${fri.getFullYear()}`;
}
function getShortLabel(dateStr) {
  const d=new Date(dateStr+'T12:00:00'),day=d.getDay(),diff=d.getDate()-day+(day===0?-6:1);
  const mon=new Date(d);mon.setDate(diff);
  return mon.toLocaleDateString('en-US',{month:'short',day:'numeric'});
}

